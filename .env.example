# LiveKit (auto-overridden in Docker Compose)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# LiveKit WebRTC — your Mac's LAN IP (reachable from browser and Docker containers)
# Find it with: ipconfig getifaddr en0
NODE_IP=

# OpenAI
OPENAI_API_KEY=sk-...

# Speechmatics
SPEECHMATICS_API_KEY=

# ElevenLabs (plugin expects ELEVEN_API_KEY)
ELEVEN_API_KEY=

# GitHub (token is passed to the MCP sidecar via docker-compose.yml)
GITHUB_TOKEN=
